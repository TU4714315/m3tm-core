{
  "name": "M3TM GhostIntel Lab",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "forwardPorts": [7331],
  "portsAttributes": {
    "7331": {
      "label": "GhostIntel Web UI",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "bash scripts/install_ghostintel_linux.sh || true"
}
